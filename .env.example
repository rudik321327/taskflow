# Application
APP_ENV=development
APP_PORT=8080
APP_NAME=taskflow
SHUTDOWN_TIMEOUT=15s

# PostgreSQL
DB_HOST=postgres
DB_PORT=5432
DB_USER=taskflow
DB_PASSWORD=taskflow_secret
DB_NAME=taskflow
DB_SSLMODE=disable
DB_MAX_CONNS=20

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=super_secret_change_me_in_production
JWT_TTL=24h

# gRPC notification service
GRPC_NOTIFICATION_ADDR=notification:50051
GRPC_PORT=50051

# Rate limiting (requests per minute per IP)
RATE_LIMIT_RPM=120

# Worker pool
WORKER_POOL_SIZE=3
WORKER_QUEUE_SIZE=256
